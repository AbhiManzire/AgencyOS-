  @@index([tenantId, clientId, isPinned], map: "idx_client_notes_tenant_id_client_id_is_pinned")
  @@map("client_notes")
}

/// Append-only tenant-scoped client activity timeline entry.
model ClientActivity {
  id           String             @id @db.Uuid
  tenantId     String             @map("tenant_id") @db.Uuid
  clientId     String             @map("client_id") @db.Uuid

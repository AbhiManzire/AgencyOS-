generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & Access — platform and tenant-scoped foundation
// See blueprint/04_DATABASE_RULES.md
// Business module models are added in subsequent sprints.
// ---------------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DEPROVISIONED

  @@map("tenant_status")
}

/// Platform-scoped tenant registry (workspace).
model Tenant {
  id        String       @id @db.Uuid
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  isActive  Boolean      @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  createdByUser User? @relation("TenantCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("TenantUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("TenantDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  roles     Role[]
  userRoles UserRole[]
  rolePermissions RolePermission[]
  workspace Workspace?
  departments Department[]
  teams       Team[]
  employees   Employee[]
  clients        Client[]
  clientContacts ClientContact[]
  clientNotes ClientNote[]
  clientActivities ClientActivity[]
  clientTags  Tag[]
  clientTagAssignments ClientTag[]
  projectTagAssignments ProjectTag[]
  taskTagAssignments    TaskTag[]
  clientDocuments ClientDocument[]
  clientCustomFieldValues ClientCustomFieldValue[]
  activities              Activity[]
  comments                Comment[]
  files                   File[]
  timeEntries             TimeEntry[]
  deals                   Deal[]
  dealFollowUps           DealFollowUp[]
  dealStageHistories      DealStageHistory[]
  quotes                  Quote[]
  quoteLineItems          QuoteLineItem[]
  quoteRevisions          QuoteRevision[]
  proposals               Proposal[]
  proposalVersions        ProposalVersion[]
  invoices                Invoice[]
  invoiceLineItems        InvoiceLineItem[]
  payments                Payment[]
  vendors                 Vendor[]
  expenses                Expense[]
  purchaseBills           PurchaseBill[]
  purchaseBillLineItems   PurchaseBillLineItem[]
  purchasePayments        PurchasePayment[]
  creditNotes             CreditNote[]
  creditNoteApplications  CreditNoteApplication[]
  recurringInvoices       RecurringInvoice[]
  recurringExpenses       RecurringExpense[]
  ledgerEntries           LedgerEntry[]
  projects                Project[]
  projectMembers          ProjectMember[]
  projectMilestones       ProjectMilestone[]
  tasks                   Task[]
  taskDependencies        TaskDependency[]
  leads                   Lead[]
  leadTagAssignments      LeadTag[]
  workflows               Workflow[]
  workflowTriggers        WorkflowTrigger[]
  workflowActions         WorkflowAction[]
  workflowConditions      WorkflowCondition[]
  workflowSchedules       WorkflowSchedule[]
  workflowExecutions      WorkflowExecution[]
  workflowExecutionLogs   WorkflowExecutionLog[]
  scheduledReports        ScheduledReport[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  userInvitations         UserInvitation[]
  personalAccessTokens    PersonalAccessToken[]
  featureFlags            FeatureFlag[]
  aiProviderConfigs       AiProviderConfig[]
  aiPromptTemplates       AiPromptTemplate[]
  aiConversations         AiConversation[]
  aiMessages              AiMessage[]
  aiUsageEvents           AiUsageEvent[]
  aiSettings              AiSettings[]

  @@index([status], map: "idx_platform_tenants_status")
  @@index([deletedAt], map: "idx_platform_tenants_deleted_at")
  @@map("platform_tenants")
}

/// Platform-scoped user identity (Keycloak-linked).
model User {
  id               String  @id @db.Uuid
  keycloakSubject  String  @unique @map("keycloak_subject")
  email            String  @unique
  firstName        String? @map("first_name")
  lastName         String? @map("last_name")
  displayName      String? @map("display_name")
  avatarUrl        String? @map("avatar_url")
  isActive         Boolean @default(true) @map("is_active")
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamptz

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  createdByUser User? @relation("UserCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("UserDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  tenantsCreated  Tenant[] @relation("TenantCreatedBy")
  tenantsUpdated  Tenant[] @relation("TenantUpdatedBy")
  tenantsDeleted  Tenant[] @relation("TenantDeletedBy")
  usersCreated    User[]   @relation("UserCreatedBy")
  usersUpdated    User[]   @relation("UserUpdatedBy")
  usersDeleted    User[]   @relation("UserDeletedBy")
  rolesCreated    Role[]   @relation("RoleCreatedBy")
  rolesUpdated    Role[]   @relation("RoleUpdatedBy")
  rolesDeleted    Role[]   @relation("RoleDeletedBy")
  userRoles       UserRole[]
  userRolesCreated UserRole[] @relation("UserRoleCreatedBy")
  userRolesUpdated UserRole[] @relation("UserRoleUpdatedBy")
  userRolesDeleted UserRole[] @relation("UserRoleDeletedBy")
  permissionsCreated Permission[] @relation("PermissionCreatedBy")
  permissionsUpdated Permission[] @relation("PermissionUpdatedBy")
  permissionsDeleted Permission[] @relation("PermissionDeletedBy")
  agenciesCreated  Agency[]     @relation("AgencyCreatedBy")
  agenciesUpdated  Agency[]     @relation("AgencyUpdatedBy")
  agenciesDeleted  Agency[]     @relation("AgencyDeletedBy")
  workspacesCreated Workspace[] @relation("WorkspaceCreatedBy")
  workspacesUpdated Workspace[] @relation("WorkspaceUpdatedBy")
  workspacesDeleted Workspace[] @relation("WorkspaceDeletedBy")
  departmentsCreated Department[] @relation("DepartmentCreatedBy")
  departmentsUpdated Department[] @relation("DepartmentUpdatedBy")
  departmentsDeleted Department[] @relation("DepartmentDeletedBy")
  teamsCreated     Team[]       @relation("TeamCreatedBy")
  teamsUpdated     Team[]       @relation("TeamUpdatedBy")
  teamsDeleted     Team[]       @relation("TeamDeletedBy")
  employeesCreated Employee[]   @relation("EmployeeCreatedBy")
  employeesUpdated Employee[]   @relation("EmployeeUpdatedBy")
  employeesDeleted Employee[]   @relation("EmployeeDeletedBy")
  employees        Employee[]
  clientsOwned     Client[]     @relation("ClientOwner")
  clientsCreated   Client[]     @relation("ClientCreatedBy")
  clientsUpdated   Client[]     @relation("ClientUpdatedBy")
  clientsDeleted   Client[]     @relation("ClientDeletedBy")
  clientContactsCreated ClientContact[] @relation("ClientContactCreatedBy")
  clientContactsUpdated ClientContact[] @relation("ClientContactUpdatedBy")
  clientContactsDeleted ClientContact[] @relation("ClientContactDeletedBy")
  clientNotesCreated ClientNote[] @relation("ClientNoteCreatedBy")
  clientNotesUpdated ClientNote[] @relation("ClientNoteUpdatedBy")
  clientActivitiesActed ClientActivity[] @relation("ClientActivityActor")
  tagsCreated      Tag[]        @relation("TagCreatedBy")
  tagsUpdated      Tag[]        @relation("TagUpdatedBy")
  tagsDeleted      Tag[]        @relation("TagDeletedBy")
  clientDocumentsUploaded ClientDocument[] @relation("ClientDocumentUploader")
  clientDocumentsDeleted  ClientDocument[] @relation("ClientDocumentDeletedBy")
  clientCustomFieldValuesCreated ClientCustomFieldValue[] @relation("ClientCustomFieldValueCreatedBy")
  clientCustomFieldValuesUpdated ClientCustomFieldValue[] @relation("ClientCustomFieldValueUpdatedBy")
  activitiesActed                Activity[]               @relation("ActivityActor")
  commentsAuthored               Comment[]                @relation("CommentAuthor")
  commentsCreated                Comment[]                @relation("CommentCreatedBy")
  commentsUpdated                Comment[]                @relation("CommentUpdatedBy")
  commentsDeleted                Comment[]                @relation("CommentDeletedBy")
  filesUploaded                  File[]                   @relation("FileUploadedBy")
  projectsManaged                Project[]                @relation("ProjectManager")
  projectsCreated                Project[]                @relation("ProjectCreatedBy")
  projectsUpdated                Project[]                @relation("ProjectUpdatedBy")
  projectsDeleted                Project[]                @relation("ProjectDeletedBy")
  projectMemberships             ProjectMember[]
  projectMembersCreated          ProjectMember[] @relation("ProjectMemberCreatedBy")
  projectMembersUpdated          ProjectMember[] @relation("ProjectMemberUpdatedBy")
  projectMembersDeleted          ProjectMember[] @relation("ProjectMemberDeletedBy")
  projectMilestonesOwned         ProjectMilestone[] @relation("ProjectMilestoneOwner")
  projectMilestonesCreated       ProjectMilestone[] @relation("ProjectMilestoneCreatedBy")
  projectMilestonesUpdated       ProjectMilestone[] @relation("ProjectMilestoneUpdatedBy")
  projectMilestonesDeleted       ProjectMilestone[] @relation("ProjectMilestoneDeletedBy")
  tasksAssigned                  Task[]             @relation("TaskAssignee")
  tasksReported                  Task[]             @relation("TaskReporter")
  tasksCreated                   Task[]             @relation("TaskCreatedBy")
  tasksUpdated                   Task[]             @relation("TaskUpdatedBy")
  tasksDeleted                   Task[]             @relation("TaskDeletedBy")
  timeEntries                    TimeEntry[]        @relation("TimeEntryUser")
  timeEntriesCreated             TimeEntry[]        @relation("TimeEntryCreatedBy")
  timeEntriesUpdated             TimeEntry[]        @relation("TimeEntryUpdatedBy")
  timeEntriesDeleted             TimeEntry[]        @relation("TimeEntryDeletedBy")
  dealsOwned                     Deal[]             @relation("DealOwner")
  dealsCreated                   Deal[]             @relation("DealCreatedBy")
  dealsUpdated                   Deal[]             @relation("DealUpdatedBy")
  dealsDeleted                   Deal[]             @relation("DealDeletedBy")
  dealFollowUpsOwned             DealFollowUp[]     @relation("DealFollowUpOwner")
  dealFollowUpsCreated           DealFollowUp[]     @relation("DealFollowUpCreatedBy")
  dealFollowUpsUpdated           DealFollowUp[]     @relation("DealFollowUpUpdatedBy")
  dealFollowUpsDeleted           DealFollowUp[]     @relation("DealFollowUpDeletedBy")
  dealStageHistoriesChanged      DealStageHistory[] @relation("DealStageHistoryChangedBy")
  quotesCreated                  Quote[]            @relation("QuoteCreatedBy")
  quotesUpdated                  Quote[]            @relation("QuoteUpdatedBy")
  quotesDeleted                  Quote[]            @relation("QuoteDeletedBy")
  quoteLineItemsCreated          QuoteLineItem[]    @relation("QuoteLineItemCreatedBy")
  quoteLineItemsUpdated          QuoteLineItem[]    @relation("QuoteLineItemUpdatedBy")
  quoteLineItemsDeleted          QuoteLineItem[]    @relation("QuoteLineItemDeletedBy")
  quoteRevisionsCreated          QuoteRevision[]    @relation("QuoteRevisionCreatedBy")
  proposalsCreated               Proposal[]         @relation("ProposalCreatedBy")
  proposalsUpdated               Proposal[]         @relation("ProposalUpdatedBy")
  proposalsDeleted               Proposal[]         @relation("ProposalDeletedBy")
  proposalVersionsCreated        ProposalVersion[]  @relation("ProposalVersionCreatedBy")
  invoicesCreated                Invoice[]          @relation("InvoiceCreatedBy")
  invoicesUpdated                Invoice[]          @relation("InvoiceUpdatedBy")
  invoicesDeleted                Invoice[]          @relation("InvoiceDeletedBy")
  invoiceLineItemsCreated        InvoiceLineItem[]  @relation("InvoiceLineItemCreatedBy")
  invoiceLineItemsUpdated        InvoiceLineItem[]  @relation("InvoiceLineItemUpdatedBy")
  invoiceLineItemsDeleted        InvoiceLineItem[]  @relation("InvoiceLineItemDeletedBy")
  paymentsCreated                Payment[]          @relation("PaymentCreatedBy")
  paymentsUpdated                Payment[]          @relation("PaymentUpdatedBy")
  paymentsDeleted                Payment[]          @relation("PaymentDeletedBy")
  vendorsCreated                 Vendor[]           @relation("VendorCreatedBy")
  vendorsUpdated                 Vendor[]           @relation("VendorUpdatedBy")
  vendorsDeleted                 Vendor[]           @relation("VendorDeletedBy")
  expensesAsEmployee             Expense[]          @relation("ExpenseEmployee")
  expensesCreated                Expense[]          @relation("ExpenseCreatedBy")
  expensesUpdated                Expense[]          @relation("ExpenseUpdatedBy")
  expensesDeleted                Expense[]          @relation("ExpenseDeletedBy")
  purchaseBillsCreated           PurchaseBill[]     @relation("PurchaseBillCreatedBy")
  purchaseBillsUpdated           PurchaseBill[]     @relation("PurchaseBillUpdatedBy")
  purchaseBillsDeleted           PurchaseBill[]     @relation("PurchaseBillDeletedBy")
  purchaseBillLineItemsCreated   PurchaseBillLineItem[] @relation("PurchaseBillLineItemCreatedBy")
  purchaseBillLineItemsUpdated   PurchaseBillLineItem[] @relation("PurchaseBillLineItemUpdatedBy")
  purchaseBillLineItemsDeleted   PurchaseBillLineItem[] @relation("PurchaseBillLineItemDeletedBy")
  purchasePaymentsCreated        PurchasePayment[]  @relation("PurchasePaymentCreatedBy")
  purchasePaymentsUpdated        PurchasePayment[]  @relation("PurchasePaymentUpdatedBy")
  purchasePaymentsDeleted        PurchasePayment[]  @relation("PurchasePaymentDeletedBy")
  creditNotesCreated             CreditNote[]       @relation("CreditNoteCreatedBy")
  creditNotesUpdated             CreditNote[]       @relation("CreditNoteUpdatedBy")
  creditNotesDeleted             CreditNote[]       @relation("CreditNoteDeletedBy")
  creditNoteApplicationsCreated  CreditNoteApplication[] @relation("CreditNoteApplicationCreatedBy")
  recurringInvoicesCreated       RecurringInvoice[] @relation("RecurringInvoiceCreatedBy")
  recurringInvoicesUpdated       RecurringInvoice[] @relation("RecurringInvoiceUpdatedBy")
  recurringInvoicesDeleted       RecurringInvoice[] @relation("RecurringInvoiceDeletedBy")
  recurringExpensesCreated       RecurringExpense[] @relation("RecurringExpenseCreatedBy")
  recurringExpensesUpdated       RecurringExpense[] @relation("RecurringExpenseUpdatedBy")
  recurringExpensesDeleted       RecurringExpense[] @relation("RecurringExpenseDeletedBy")
  ledgerEntriesCreated           LedgerEntry[]      @relation("LedgerEntryCreatedBy")
  leadsAssigned                  Lead[]             @relation("LeadAssignee")
  leadsCreated                   Lead[]             @relation("LeadCreatedBy")
  leadsUpdated                   Lead[]             @relation("LeadUpdatedBy")
  leadsDeleted                   Lead[]             @relation("LeadDeletedBy")
  workflowsCreated               Workflow[]         @relation("WorkflowCreatedBy")
  workflowsUpdated               Workflow[]         @relation("WorkflowUpdatedBy")
  workflowsDeleted               Workflow[]         @relation("WorkflowDeletedBy")
  workflowExecutionsTriggered    WorkflowExecution[] @relation("WorkflowExecutionTriggeredBy")
  scheduledReportsCreated        ScheduledReport[]  @relation("ScheduledReportCreatedBy")
  scheduledReportsUpdated        ScheduledReport[]  @relation("ScheduledReportUpdatedBy")
  scheduledReportsDeleted        ScheduledReport[]  @relation("ScheduledReportDeletedBy")
  auditLogsActed                 AuditLog[]         @relation("AuditLogActor")
  notificationsReceived          Notification[]     @relation("NotificationRecipient")
  invitationsSent                UserInvitation[]   @relation("UserInvitationInviter")
  personalAccessTokens           PersonalAccessToken[] @relation("PersonalAccessTokenOwner")
  aiConversationsOwned           AiConversation[]   @relation("AiConversationOwner")
  aiMessagesCreated              AiMessage[]        @relation("AiMessageCreatedBy")
  aiUsageEventsActed             AiUsageEvent[]     @relation("AiUsageEventActor")
  employeesManaged               Employee[]         @relation("EmployeeManager")

  @@index([deletedAt], map: "idx_users_deleted_at")
  @@map("users")
}

/// Platform-scoped permission catalog.
model Permission {
  id          String  @id @db.Uuid
  key         String  @unique
  name        String
  description String?
  module      String?

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  createdByUser User? @relation("PermissionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("PermissionUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("PermissionDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  rolePermissions RolePermission[]

  @@index([module], map: "idx_permissions_module")
  @@index([deletedAt], map: "idx_permissions_deleted_at")
  @@map("permissions")
}

/// Tenant-scoped role definition.
model Role {
  id          String  @id @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  name        String
  slug        String
  description String?
  isSystem    Boolean @default(false) @map("is_system")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdByUser User?        @relation("RoleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?        @relation("RoleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?        @relation("RoleDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  userRoles     UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, slug], map: "uq_roles_tenant_id_slug")
  @@index([tenantId], map: "idx_roles_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_roles_tenant_id_deleted_at")
  @@map("roles")
}

/// Tenant-scoped user-to-role assignment.
model UserRole {
  id       String @id @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
  roleId   String @map("role_id") @db.Uuid

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user          User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  role          Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdByUser User?  @relation("UserRoleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?  @relation("UserRoleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?  @relation("UserRoleDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId, roleId], map: "uq_user_roles_tenant_id_user_id_role_id")
  @@index([tenantId], map: "idx_user_roles_tenant_id")
  @@index([tenantId, userId], map: "idx_user_roles_tenant_id_user_id")
  @@index([tenantId, roleId], map: "idx_user_roles_tenant_id_role_id")
  @@index([tenantId, deletedAt], map: "idx_user_roles_tenant_id_deleted_at")
  @@map("user_roles")
}

/// Tenant-scoped role-to-permission assignment.
model RolePermission {
  id           String @id @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  createdAt DateTime @map("created_at") @db.Timestamptz

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([tenantId, roleId, permissionId], map: "uq_role_permissions_tenant_id_role_id_permission_id")
  @@index([tenantId], map: "idx_role_permissions_tenant_id")
  @@index([tenantId, roleId], map: "idx_role_permissions_tenant_id_role_id")
  @@map("role_permissions")
}

// ---------------------------------------------------------------------------
// Organization — agency structure and workforce foundation
// See blueprint/03_ARCHITECTURE.md §3–§4, blueprint/04_DATABASE_RULES.md
// ---------------------------------------------------------------------------

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED

  @@map("employment_status")
}

/// Platform-scoped agency organization (supports multi-workspace agency groups).
model Agency {
  id        String  @id @db.Uuid
  name      String
  slug      String  @unique
  legalName String? @map("legal_name")
  logoUrl   String? @map("logo_url")
  addressLine1 String? @map("address_line_1")
  addressLine2 String? @map("address_line_2")
  city         String?
  stateRegion  String? @map("state_region")
  postalCode   String? @map("postal_code")
  countryCode  String? @map("country_code") @db.Char(2)
  gstin        String?
  pan          String?
  brandPrimaryColor String? @map("brand_primary_color")
  brandSecondaryColor String? @map("brand_secondary_color")
  isActive  Boolean @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  createdByUser User? @relation("AgencyCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("AgencyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("AgencyDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  workspaces Workspace[]

  @@index([deletedAt], map: "idx_agencies_deleted_at")
  @@map("agencies")
}

/// Tenant-scoped workspace — user-facing operational unit (1:1 with tenant isolation boundary).
model Workspace {
  id       String @id @db.Uuid
  tenantId String @unique @map("tenant_id") @db.Uuid
  agencyId String @map("agency_id") @db.Uuid
  name     String
  slug     String
  timezone String @default("UTC")
  currency String @default("USD") @db.Char(3)
  logoUrl  String? @map("logo_url")
  addressLine1 String? @map("address_line_1")
  addressLine2 String? @map("address_line_2")
  city         String?
  stateRegion  String? @map("state_region")
  postalCode   String? @map("postal_code")
  countryCode  String? @map("country_code") @db.Char(2)
  gstin        String?
  pan          String?
  financialYearStartMonth Int @default(4) @map("financial_year_start_month")
  businessHoursStart String @default("09:00") @map("business_hours_start")
  businessHoursEnd   String @default("18:00") @map("business_hours_end")
  workingDays  Json    @default("[1,2,3,4,5]") @map("working_days")
  language     String  @default("en")
  dateFormat   String  @default("YYYY-MM-DD") @map("date_format")
  numberFormat String  @default("en-US") @map("number_format")
  /// Category preferences: branding, invoice, finance, sales, task, project, notification, email, security, system.
  preferencesJson Json @default("{}") @map("preferences_json")
  isActive Boolean @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  agency        Agency       @relation(fields: [agencyId], references: [id], onDelete: Restrict)
  createdByUser User?        @relation("WorkspaceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?        @relation("WorkspaceUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?        @relation("WorkspaceDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  departments   Department[]
  employees     Employee[]
  clients        Client[]
  clientContacts ClientContact[]
  tags           Tag[]
  activities     Activity[]
  comments       Comment[]
  files          File[]
  timeEntries    TimeEntry[]
  deals          Deal[]
  dealFollowUps  DealFollowUp[]
  dealStageHistories DealStageHistory[]
  quotes         Quote[]
  quoteLineItems QuoteLineItem[]
  quoteRevisions QuoteRevision[]
  proposals      Proposal[]
  proposalVersions ProposalVersion[]
  invoices       Invoice[]
  invoiceLineItems InvoiceLineItem[]
  payments       Payment[]
  vendors        Vendor[]

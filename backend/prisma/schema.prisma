enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  ARCHIVED

  @@map("client_status")
}

enum ClientSource {
  REFERRAL
  INBOUND
  OUTBOUND
  IMPORT
  SALES_CONVERSION

  @@map("client_source")
}

enum ClientActivityType {
  STATUS_CHANGE
  NOTE
  DOCUMENT
  OWNER_CHANGE
  CONTACT
  INTEGRATION_EVENT

  @@map("client_activity_type")
}

enum ClientDocumentType {
  CONTRACT
  BRIEF
  PROPOSAL
  OTHER

  @@map("client_document_type")
}

/// Tenant-scoped client organization account.
model Client {
  id                  String        @id @db.Uuid
  tenantId            String        @map("tenant_id") @db.Uuid
  workspaceId         String        @map("workspace_id") @db.Uuid
  displayName         String        @map("display_name")
  slug                String
  status              ClientStatus  @default(PROSPECT)
  legalName           String?       @map("legal_name")
  clientCode          String?       @map("client_code")
  industry            String?
  website             String?
  phone               String?
  email               String?
  gstin               String?
  pan                 String?
  currency            String?       @db.Char(3)
  /// Billing address (existing address columns preserved for backward compatibility).
  addressLine1        String?       @map("address_line_1")
  addressLine2        String?       @map("address_line_2")
  city                String?
  stateRegion         String?       @map("state_region")
  postalCode          String?       @map("postal_code")
  countryCode         String?       @map("country_code") @db.Char(2)
  shippingAddressLine1 String?      @map("shipping_address_line_1")
  shippingAddressLine2 String?      @map("shipping_address_line_2")
  shippingCity        String?       @map("shipping_city")
  shippingStateRegion String?       @map("shipping_state_region")
  shippingPostalCode  String?       @map("shipping_postal_code")
  shippingCountryCode String?       @map("shipping_country_code") @db.Char(2)
  ownerUserId         String?       @map("owner_user_id") @db.Uuid
  source              ClientSource?
  externalReferenceId String?       @map("external_reference_id")
  becameClientAt      DateTime?     @map("became_client_at") @db.Date
  paymentTermsDays    Int?          @default(30) @map("payment_terms_days")
  creditLimit         Decimal?      @map("credit_limit") @db.Decimal(14, 2)

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  ownerUser     User?     @relation("ClientOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByUser User?     @relation("ClientCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?     @relation("ClientUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?     @relation("ClientDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  clientContacts ClientContact[]
  notes          ClientNote[]
  activities    ClientActivity[]
  tags          ClientTag[]
  documents     ClientDocument[]
  customFields  ClientCustomFieldValue[]
  projects      Project[]
  deals         Deal[]
  quotes        Quote[]
  invoices      Invoice[]
  creditNotes   CreditNote[]
  ledgerEntries LedgerEntry[]
  convertedFromLeads Lead[] @relation("LeadConvertedClient")

  @@unique([tenantId, workspaceId, displayName], map: "uq_clients_tenant_id_workspace_id_display_name")
  @@unique([tenantId, workspaceId, slug], map: "uq_clients_tenant_id_workspace_id_slug")
  @@unique([tenantId, workspaceId, clientCode], map: "uq_clients_tenant_id_workspace_id_client_code")
  @@index([tenantId], map: "idx_clients_tenant_id")
  @@index([tenantId, workspaceId], map: "idx_clients_tenant_id_workspace_id")
  @@index([tenantId, status], map: "idx_clients_tenant_id_status")
  @@index([tenantId, ownerUserId], map: "idx_clients_tenant_id_owner_user_id")
  @@index([tenantId, deletedAt], map: "idx_clients_tenant_id_deleted_at")
  @@map("clients")
}


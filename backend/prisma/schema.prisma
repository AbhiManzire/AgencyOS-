  @@index([tenantId], map: "idx_project_milestones_tenant_id")
  @@index([tenantId, workspaceId, projectId, sortOrder], map: "idx_proj_milestones_scope_project_sort")
  @@index([tenantId, workspaceId, projectId, status, deletedAt], map: "idx_proj_milestones_scope_status_del")

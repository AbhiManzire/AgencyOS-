  id             String         @id @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  conversationId String?        @map("conversation_id") @db.Uuid
  actorUserId    String?        @map("actor_user_id") @db.Uuid
  providerKind   AiProviderKind @map("provider_kind")
  model          String?
  promptTokens   Int            @default(0) @map("prompt_tokens")
  completionTokens Int          @default(0) @map("completion_tokens")
  totalTokens    Int            @default(0) @map("total_tokens")
  estimatedCostUsd Decimal?     @map("estimated_cost_usd") @db.Decimal(12, 6)
  featureKey     String?        @map("feature_key")
  metadata       Json?
  occurredAt     DateTime       @map("occurred_at") @db.Timestamptz

  createdAt DateTime @map("created_at") @db.Timestamptz

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  conversation AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  actorUser    User?           @relation("AiUsageEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, workspaceId, occurredAt], map: "idx_ai_usage_events_scope_occurred")
  @@index([tenantId, workspaceId, providerKind, occurredAt], map: "idx_ai_usage_events_scope_provider")
  @@index([tenantId, workspaceId, featureKey, occurredAt], map: "idx_ai_usage_events_scope_feature")
  @@map("ai_usage_events")
}

/// Workspace AI settings and defaults.
model AiSettings {
  id                 String  @id @db.Uuid
  tenantId           String  @map("tenant_id") @db.Uuid
  workspaceId        String  @map("workspace_id") @db.Uuid
  enabled            Boolean @default(false)
  defaultProviderKind AiProviderKind? @map("default_provider_kind")
  defaultModel       String? @map("default_model")
  maxTokensPerRequest Int    @default(4096) @map("max_tokens_per_request")
  monthlyTokenBudget Int?    @map("monthly_token_budget")
  auditPrompts       Boolean @default(true) @map("audit_prompts")
  preferences        Json    @default("{}")

  createdAt DateTime @map("created_at") @db.Timestamptz
  updatedAt DateTime @map("updated_at") @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@unique([tenantId, workspaceId], map: "uq_ai_settings_scope")
  @@map("ai_settings")
}


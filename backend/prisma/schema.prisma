  updatedByUser User?       @relation("EmployeeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?       @relation("EmployeeDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId], map: "uq_employees_tenant_id_user_id")
  @@index([tenantId], map: "idx_employees_tenant_id")
  @@index([tenantId, workspaceId], map: "idx_employees_tenant_id_workspace_id")
  @@index([tenantId, departmentId], map: "idx_employees_tenant_id_department_id")
  @@index([tenantId, teamId], map: "idx_employees_tenant_id_team_id")
  @@index([tenantId, managerUserId], map: "idx_employees_tenant_id_manager_user_id")
  @@index([tenantId, deletedAt], map: "idx_employees_tenant_id_deleted_at")
  @@map("employees")
}


/// Tenant-scoped sales opportunity in the pipeline.
model Deal {
  id                 String       @id @db.Uuid
  tenantId           String       @map("tenant_id") @db.Uuid
  workspaceId        String       @map("workspace_id") @db.Uuid
  clientId           String       @map("client_id") @db.Uuid
  contactId          String?      @map("contact_id") @db.Uuid
  leadId             String?      @map("lead_id") @db.Uuid
  title              String
  value              Decimal      @db.Decimal(14, 2)
  currency           String       @default("USD") @db.Char(3)
  expectedCloseDate  DateTime?    @map("expected_close_date") @db.Date
  ownerUserId        String?      @map("owner_user_id") @db.Uuid
  stage              DealStage    @default(NEW)
  service            String?
  probability        Int?         @default(0)
  priority           DealPriority @default(MEDIUM)
  stageEnteredAt     DateTime?    @map("stage_entered_at") @db.Timestamptz
  convertedProjectId String?      @map("converted_project_id") @db.Uuid
  wonAt              DateTime?    @map("won_at") @db.Timestamptz
  lostAt             DateTime?    @map("lost_at") @db.Timestamptz

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  client           Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  contact          ClientContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead             Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  ownerUser        User?          @relation("DealOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  convertedProject Project?       @relation("DealConvertedProject", fields: [convertedProjectId], references: [id], onDelete: SetNull)
  createdByUser    User?          @relation("DealCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser    User?          @relation("DealUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser    User?          @relation("DealDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  followUps        DealFollowUp[]
  stageHistory     DealStageHistory[]
  quotes           Quote[]
  proposals        Proposal[]
  invoices         Invoice[]
  sourceProjects   Project[]      @relation("ProjectSourceDeal")

  @@index([tenantId], map: "idx_deals_tenant_id")
  @@index([tenantId, workspaceId, stage, deletedAt], map: "idx_deals_scope_stage_deleted")
  @@index([tenantId, workspaceId, ownerUserId, deletedAt], map: "idx_deals_scope_owner_deleted")
  @@index([tenantId, workspaceId, clientId, deletedAt], map: "idx_deals_scope_client_deleted")
  @@index([tenantId, workspaceId, leadId, deletedAt], map: "idx_deals_scope_lead_deleted")
  @@index([tenantId, workspaceId, priority, deletedAt], map: "idx_deals_scope_priority_deleted")
  @@map("deals")
}

/// Stage transition history for deal pipeline analytics.

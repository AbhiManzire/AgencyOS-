generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & Access — platform and tenant-scoped foundation
// See blueprint/04_DATABASE_RULES.md
// Business module models are added in subsequent sprints.
// ---------------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DEPROVISIONED

  @@map("tenant_status")
}

/// Platform-scoped tenant registry (workspace).
model Tenant {
  id        String       @id @db.Uuid
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  isActive  Boolean      @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  createdByUser User? @relation("TenantCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("TenantUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("TenantDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  roles     Role[]
  userRoles UserRole[]
  workspace Workspace?
  departments Department[]
  teams       Team[]
  employees   Employee[]
  clients     Client[]
  contacts    Contact[]
  clientNotes ClientNote[]
  clientActivities ClientActivity[]
  clientTags  Tag[]
  clientTagAssignments ClientTag[]
  clientDocuments ClientDocument[]
  clientCustomFieldValues ClientCustomFieldValue[]

  @@index([status], map: "idx_platform_tenants_status")
  @@index([deletedAt], map: "idx_platform_tenants_deleted_at")
  @@map("platform_tenants")
}

/// Platform-scoped user identity (Keycloak-linked).
model User {
  id               String  @id @db.Uuid
  keycloakSubject  String  @unique @map("keycloak_subject")
  email            String  @unique
  firstName        String? @map("first_name")
  lastName         String? @map("last_name")
  displayName      String? @map("display_name")
  isActive         Boolean @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  createdByUser User? @relation("UserCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("UserDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  tenantsCreated  Tenant[] @relation("TenantCreatedBy")
  tenantsUpdated  Tenant[] @relation("TenantUpdatedBy")
  tenantsDeleted  Tenant[] @relation("TenantDeletedBy")
  usersCreated    User[]   @relation("UserCreatedBy")
  usersUpdated    User[]   @relation("UserUpdatedBy")
  usersDeleted    User[]   @relation("UserDeletedBy")
  rolesCreated    Role[]   @relation("RoleCreatedBy")
  rolesUpdated    Role[]   @relation("RoleUpdatedBy")
  rolesDeleted    Role[]   @relation("RoleDeletedBy")
  userRoles       UserRole[]
  userRolesCreated UserRole[] @relation("UserRoleCreatedBy")
  userRolesUpdated UserRole[] @relation("UserRoleUpdatedBy")
  userRolesDeleted UserRole[] @relation("UserRoleDeletedBy")
  permissionsCreated Permission[] @relation("PermissionCreatedBy")
  permissionsUpdated Permission[] @relation("PermissionUpdatedBy")
  permissionsDeleted Permission[] @relation("PermissionDeletedBy")
  agenciesCreated  Agency[]     @relation("AgencyCreatedBy")
  agenciesUpdated  Agency[]     @relation("AgencyUpdatedBy")
  agenciesDeleted  Agency[]     @relation("AgencyDeletedBy")
  workspacesCreated Workspace[] @relation("WorkspaceCreatedBy")
  workspacesUpdated Workspace[] @relation("WorkspaceUpdatedBy")
  workspacesDeleted Workspace[] @relation("WorkspaceDeletedBy")
  departmentsCreated Department[] @relation("DepartmentCreatedBy")
  departmentsUpdated Department[] @relation("DepartmentUpdatedBy")
  departmentsDeleted Department[] @relation("DepartmentDeletedBy")
  teamsCreated     Team[]       @relation("TeamCreatedBy")
  teamsUpdated     Team[]       @relation("TeamUpdatedBy")
  teamsDeleted     Team[]       @relation("TeamDeletedBy")
  employeesCreated Employee[]   @relation("EmployeeCreatedBy")
  employeesUpdated Employee[]   @relation("EmployeeUpdatedBy")
  employeesDeleted Employee[]   @relation("EmployeeDeletedBy")
  employees        Employee[]
  clientsOwned     Client[]     @relation("ClientOwner")
  clientsCreated   Client[]     @relation("ClientCreatedBy")
  clientsUpdated   Client[]     @relation("ClientUpdatedBy")
  clientsDeleted   Client[]     @relation("ClientDeletedBy")
  contactsCreated  Contact[]    @relation("ContactCreatedBy")
  contactsUpdated  Contact[]    @relation("ContactUpdatedBy")
  contactsDeleted  Contact[]    @relation("ContactDeletedBy")
  clientNotesCreated ClientNote[] @relation("ClientNoteCreatedBy")
  clientNotesUpdated ClientNote[] @relation("ClientNoteUpdatedBy")
  clientActivitiesActed ClientActivity[] @relation("ClientActivityActor")
  tagsCreated      Tag[]        @relation("TagCreatedBy")
  tagsUpdated      Tag[]        @relation("TagUpdatedBy")
  tagsDeleted      Tag[]        @relation("TagDeletedBy")
  clientDocumentsUploaded ClientDocument[] @relation("ClientDocumentUploader")
  clientDocumentsDeleted  ClientDocument[] @relation("ClientDocumentDeletedBy")
  clientCustomFieldValuesCreated ClientCustomFieldValue[] @relation("ClientCustomFieldValueCreatedBy")
  clientCustomFieldValuesUpdated ClientCustomFieldValue[] @relation("ClientCustomFieldValueUpdatedBy")

  @@index([deletedAt], map: "idx_users_deleted_at")
  @@map("users")
}

/// Platform-scoped permission catalog.
model Permission {
  id          String  @id @db.Uuid
  key         String  @unique
  name        String
  description String?
  module      String?

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  createdByUser User? @relation("PermissionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("PermissionUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("PermissionDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@index([module], map: "idx_permissions_module")
  @@index([deletedAt], map: "idx_permissions_deleted_at")
  @@map("permissions")
}

/// Tenant-scoped role definition.
model Role {
  id          String  @id @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  name        String
  slug        String
  description String?
  isSystem    Boolean @default(false) @map("is_system")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdByUser User?        @relation("RoleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?        @relation("RoleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?        @relation("RoleDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  userRoles     UserRole[]

  @@unique([tenantId, slug], map: "uq_roles_tenant_id_slug")
  @@index([tenantId], map: "idx_roles_tenant_id")
  @@index([tenantId, deletedAt], map: "idx_roles_tenant_id_deleted_at")
  @@map("roles")
}

/// Tenant-scoped user-to-role assignment.
model UserRole {
  id       String @id @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
  roleId   String @map("role_id") @db.Uuid

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user          User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  role          Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdByUser User?  @relation("UserRoleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?  @relation("UserRoleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?  @relation("UserRoleDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId, roleId], map: "uq_user_roles_tenant_id_user_id_role_id")
  @@index([tenantId], map: "idx_user_roles_tenant_id")
  @@index([tenantId, userId], map: "idx_user_roles_tenant_id_user_id")
  @@index([tenantId, roleId], map: "idx_user_roles_tenant_id_role_id")
  @@index([tenantId, deletedAt], map: "idx_user_roles_tenant_id_deleted_at")
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Organization — agency structure and workforce foundation
// See blueprint/03_ARCHITECTURE.md §3–§4, blueprint/04_DATABASE_RULES.md
// ---------------------------------------------------------------------------

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED

  @@map("employment_status")
}

/// Platform-scoped agency organization (supports multi-workspace agency groups).
model Agency {
  id        String  @id @db.Uuid
  name      String
  slug      String  @unique
  legalName String? @map("legal_name")
  isActive  Boolean @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  createdByUser User? @relation("AgencyCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("AgencyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User? @relation("AgencyDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  workspaces Workspace[]

  @@index([deletedAt], map: "idx_agencies_deleted_at")
  @@map("agencies")
}

/// Tenant-scoped workspace — user-facing operational unit (1:1 with tenant isolation boundary).
model Workspace {
  id       String @id @db.Uuid
  tenantId String @unique @map("tenant_id") @db.Uuid
  agencyId String @map("agency_id") @db.Uuid
  name     String
  slug     String
  timezone String @default("UTC")
  currency String @default("USD") @db.Char(3)
  isActive Boolean @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  agency        Agency       @relation(fields: [agencyId], references: [id], onDelete: Restrict)
  createdByUser User?        @relation("WorkspaceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?        @relation("WorkspaceUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?        @relation("WorkspaceDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  departments   Department[]
  employees     Employee[]
  clients       Client[]
  tags          Tag[]

  @@unique([agencyId, slug], map: "uq_workspaces_agency_id_slug")
  @@index([tenantId], map: "idx_workspaces_tenant_id")
  @@index([agencyId], map: "idx_workspaces_agency_id")
  @@index([tenantId, deletedAt], map: "idx_workspaces_tenant_id_deleted_at")
  @@map("workspaces")
}

/// Tenant-scoped organizational department within a workspace.
model Department {
  id                 String  @id @db.Uuid
  tenantId           String  @map("tenant_id") @db.Uuid
  workspaceId        String  @map("workspace_id") @db.Uuid
  parentDepartmentId String? @map("parent_department_id") @db.Uuid
  name               String
  slug               String
  description        String?
  isActive           Boolean @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  parentDepartment Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: Restrict)
  childDepartments Department[] @relation("DepartmentHierarchy")
  createdByUser    User?        @relation("DepartmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser    User?        @relation("DepartmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser    User?        @relation("DepartmentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  teams            Team[]
  employees        Employee[]

  @@unique([tenantId, workspaceId, slug], map: "uq_departments_tenant_id_workspace_id_slug")
  @@index([tenantId], map: "idx_departments_tenant_id")
  @@index([tenantId, workspaceId], map: "idx_departments_tenant_id_workspace_id")
  @@index([tenantId, parentDepartmentId], map: "idx_departments_tenant_id_parent_department_id")
  @@index([tenantId, deletedAt], map: "idx_departments_tenant_id_deleted_at")
  @@map("departments")
}

/// Tenant-scoped team within a department.
model Team {
  id           String  @id @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  departmentId String  @map("department_id") @db.Uuid
  name         String
  slug         String
  description  String?
  isActive     Boolean @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  createdByUser User?      @relation("TeamCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?      @relation("TeamUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?      @relation("TeamDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  employees     Employee[]

  @@unique([tenantId, departmentId, slug], map: "uq_teams_tenant_id_department_id_slug")
  @@index([tenantId], map: "idx_teams_tenant_id")
  @@index([tenantId, departmentId], map: "idx_teams_tenant_id_department_id")
  @@index([tenantId, deletedAt], map: "idx_teams_tenant_id_deleted_at")
  @@map("teams")
}

/// Tenant-scoped workforce record linked to a platform user.
model Employee {
  id             String           @id @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  workspaceId    String           @map("workspace_id") @db.Uuid
  departmentId   String?          @map("department_id") @db.Uuid
  teamId         String?          @map("team_id") @db.Uuid
  employeeNumber String?          @map("employee_number")
  jobTitle       String?          @map("job_title")
  status         EmploymentStatus @default(ACTIVE)
  hiredOn        DateTime?        @map("hired_on") @db.Date
  isActive       Boolean          @default(true) @map("is_active")

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user          User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  team          Team?       @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdByUser User?       @relation("EmployeeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?       @relation("EmployeeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?       @relation("EmployeeDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId], map: "uq_employees_tenant_id_user_id")
  @@index([tenantId], map: "idx_employees_tenant_id")
  @@index([tenantId, workspaceId], map: "idx_employees_tenant_id_workspace_id")
  @@index([tenantId, departmentId], map: "idx_employees_tenant_id_department_id")
  @@index([tenantId, teamId], map: "idx_employees_tenant_id_team_id")
  @@index([tenantId, deletedAt], map: "idx_employees_tenant_id_deleted_at")
  @@map("employees")
}

// ---------------------------------------------------------------------------
// Clients — agency client relationship data model
// See blueprint/modules/clients/database.md, blueprint/04_DATABASE_RULES.md
// ---------------------------------------------------------------------------

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  ARCHIVED

  @@map("client_status")
}

enum ClientSource {
  REFERRAL
  INBOUND
  OUTBOUND
  IMPORT
  SALES_CONVERSION

  @@map("client_source")
}

enum ClientActivityType {
  STATUS_CHANGE
  NOTE
  DOCUMENT
  OWNER_CHANGE
  CONTACT
  INTEGRATION_EVENT

  @@map("client_activity_type")
}

enum ClientDocumentType {
  CONTRACT
  BRIEF
  PROPOSAL
  OTHER

  @@map("client_document_type")
}

/// Tenant-scoped client organization account.
model Client {
  id                  String        @id @db.Uuid
  tenantId            String        @map("tenant_id") @db.Uuid
  workspaceId         String        @map("workspace_id") @db.Uuid
  displayName         String        @map("display_name")
  slug                String
  status              ClientStatus  @default(PROSPECT)
  legalName           String?       @map("legal_name")
  industry            String?
  website             String?
  phone               String?
  email               String?
  addressLine1        String?       @map("address_line_1")
  addressLine2        String?       @map("address_line_2")
  city                String?
  stateRegion         String?       @map("state_region")
  postalCode          String?       @map("postal_code")
  countryCode         String?       @map("country_code") @db.Char(2)
  ownerUserId         String?       @map("owner_user_id") @db.Uuid
  source              ClientSource?
  externalReferenceId String?       @map("external_reference_id")
  becameClientAt      DateTime?     @map("became_client_at") @db.Date

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  ownerUser     User?     @relation("ClientOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByUser User?     @relation("ClientCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?     @relation("ClientUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?     @relation("ClientDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  contacts      Contact[]
  notes         ClientNote[]
  activities    ClientActivity[]
  tags          ClientTag[]
  documents     ClientDocument[]
  customFields  ClientCustomFieldValue[]

  @@unique([tenantId, workspaceId, displayName], map: "uq_clients_tenant_id_workspace_id_display_name")
  @@unique([tenantId, workspaceId, slug], map: "uq_clients_tenant_id_workspace_id_slug")
  @@index([tenantId], map: "idx_clients_tenant_id")
  @@index([tenantId, workspaceId], map: "idx_clients_tenant_id_workspace_id")
  @@index([tenantId, status], map: "idx_clients_tenant_id_status")
  @@index([tenantId, ownerUserId], map: "idx_clients_tenant_id_owner_user_id")
  @@index([tenantId, deletedAt], map: "idx_clients_tenant_id_deleted_at")
  @@map("clients")
}

/// Tenant-scoped person associated with a client account.
model Contact {
  id               String  @id @db.Uuid
  tenantId         String  @map("tenant_id") @db.Uuid
  clientId         String  @map("client_id") @db.Uuid
  firstName        String  @map("first_name")
  lastName         String? @map("last_name")
  jobTitle         String? @map("job_title")
  email            String?
  phone            String?
  isPrimary        Boolean @default(false) @map("is_primary")
  isBillingContact Boolean @default(false) @map("is_billing_contact")
  notes            String?

  createdAt        DateTime  @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId  String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client        Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdByUser User?  @relation("ContactCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?  @relation("ContactUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?  @relation("ContactDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "idx_contacts_tenant_id")
  @@index([tenantId, clientId], map: "idx_contacts_tenant_id_client_id")
  @@index([tenantId, deletedAt], map: "idx_contacts_tenant_id_deleted_at")
  @@map("contacts")
}

/// Tenant-scoped internal note on a client account.
model ClientNote {
  id       String  @id @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  clientId String  @map("client_id") @db.Uuid
  body     String
  title    String?
  isPinned Boolean @default(false) @map("is_pinned")

  createdAt       DateTime  @map("created_at") @db.Timestamptz
  updatedAt       DateTime? @map("updated_at") @db.Timestamptz
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client        Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdByUser User   @relation("ClientNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser User?  @relation("ClientNoteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "idx_client_notes_tenant_id")
  @@index([tenantId, clientId], map: "idx_client_notes_tenant_id_client_id")
  @@index([tenantId, clientId, isPinned], map: "idx_client_notes_tenant_id_client_id_is_pinned")
  @@map("client_notes")
}

/// Append-only tenant-scoped client activity timeline entry.
model ClientActivity {
  id           String             @id @db.Uuid
  tenantId     String             @map("tenant_id") @db.Uuid
  clientId     String             @map("client_id") @db.Uuid
  activityType ClientActivityType @map("activity_type")
  summary      String
  occurredAt   DateTime           @map("occurred_at") @db.Timestamptz
  actorUserId  String?            @map("actor_user_id") @db.Uuid
  entityType   String?            @map("entity_type")
  entityId     String?            @map("entity_id") @db.Uuid
  metadata     Json?

  createdAt DateTime @map("created_at") @db.Timestamptz

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client    Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  actorUser User?  @relation("ClientActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "idx_client_activities_tenant_id")
  @@index([tenantId, clientId], map: "idx_client_activities_tenant_id_client_id")
  @@index([tenantId, clientId, occurredAt], map: "idx_client_activities_tenant_id_client_id_occurred_at")
  @@index([tenantId, activityType], map: "idx_client_activities_tenant_id_activity_type")
  @@map("client_activities")
}

/// Tenant-scoped workspace label for client segmentation.
model Tag {
  id          String  @id @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  workspaceId String  @map("workspace_id") @db.Uuid
  name        String
  colorToken  String? @map("color_token")
  description String?

  createdAt       DateTime  @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @map("updated_at") @db.Timestamptz
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId String?   @map("deleted_by_user_id") @db.Uuid

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdByUser User?     @relation("TagCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?     @relation("TagUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser User?     @relation("TagDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  clientTags    ClientTag[]

  @@unique([tenantId, workspaceId, name], map: "uq_tags_tenant_id_workspace_id_name")
  @@index([tenantId], map: "idx_tags_tenant_id")
  @@index([tenantId, workspaceId], map: "idx_tags_tenant_id_workspace_id")
  @@index([tenantId, deletedAt], map: "idx_tags_tenant_id_deleted_at")
  @@map("tags")
}

/// Tenant-scoped association between a client and a tag.
model ClientTag {
  tenantId  String @map("tenant_id") @db.Uuid
  clientId  String @map("client_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid
  createdAt DateTime @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Restrict)

  @@id([tenantId, clientId, tagId])
  @@index([tenantId, tagId], map: "idx_client_tags_tenant_id_tag_id")
  @@map("client_tags")
}

/// Tenant-scoped file metadata attached to a client account.
model ClientDocument {
  id               String              @id @db.Uuid
  tenantId         String              @map("tenant_id") @db.Uuid
  clientId         String              @map("client_id") @db.Uuid
  fileName         String              @map("file_name")
  storageKey       String              @map("storage_key")
  fileSizeBytes    BigInt              @map("file_size_bytes")
  mimeType         String              @map("mime_type")
  description      String?
  documentType     ClientDocumentType? @map("document_type")
  uploadedAt       DateTime            @map("uploaded_at") @db.Timestamptz
  uploadedByUserId String              @map("uploaded_by_user_id") @db.Uuid

  createdAt       DateTime  @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  deletedByUserId String?   @map("deleted_by_user_id") @db.Uuid

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  client         Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  uploadedByUser User   @relation("ClientDocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  deletedByUser  User?  @relation("ClientDocumentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "idx_client_documents_tenant_id")
  @@index([tenantId, clientId], map: "idx_client_documents_tenant_id_client_id")
  @@index([tenantId, deletedAt], map: "idx_client_documents_tenant_id_deleted_at")
  @@map("client_documents")
}


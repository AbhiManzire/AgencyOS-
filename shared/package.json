{
  "name": "@agencyos/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types and utilities for AgencyOS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint -c ../eslint.config.mjs src --max-warnings 0",
    "lint:fix": "eslint -c ../eslint.config.mjs src --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}

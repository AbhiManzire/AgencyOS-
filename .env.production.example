# Production environment template — copy to .env before deploying
NODE_ENV=production

# v1.0 default: demo auth (no Keycloak). Set both to true when Keycloak is deployed.
AUTH_ENABLED=false
NEXT_PUBLIC_AUTH_ENABLED=false
RBAC_ENFORCED=true

# Public URLs (adjust for your domain)
CORS_ORIGIN=https://damsole.in
NEXT_PUBLIC_API_URL=https://damsole.in/api
NEXT_PUBLIC_TENANT_ID=00000000-0000-4000-8000-000000000001
NEXT_PUBLIC_WORKSPACE_ID=00000000-0000-4000-8000-000000000002
# Demo identity headers when AUTH_ENABLED=false (must match seeded users).
NEXT_PUBLIC_DEV_TENANT_ID=00000000-0000-4000-8000-000000000001
NEXT_PUBLIC_DEV_WORKSPACE_ID=00000000-0000-4000-8000-000000000002
NEXT_PUBLIC_DEV_USER_ID=00000000-0000-4000-8000-000000000003

# Keycloak OIDC (unused while AUTH_ENABLED=false — keep for future enablement)
NEXT_PUBLIC_KEYCLOAK_URL=https://damsole.in/auth
NEXT_PUBLIC_KEYCLOAK_REALM=agencyos
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=agencyos-web

# Backend
PORT=3001
API_PREFIX=api
SWAGGER_ENABLED=false
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
STORAGE_LOCAL_PATH=/app/uploads
STORAGE_MAX_FILE_SIZE_BYTES=10485760
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,text/csv,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
STORAGE_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,txt,csv,doc,docx,xls,xlsx

# AI infrastructure (keep disabled until providers are configured)
AI_ENABLED=false
AI_DEFAULT_PROVIDER=NULL

# PostgreSQL
POSTGRES_USER=agencyos
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=agencyos
DATABASE_URL=postgresql://agencyos:change-me-strong-password@postgres:5432/agencyos?schema=public

# Redis
REDIS_URL=redis://redis:6379

# Keycloak (optional until AUTH_ENABLED=true)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin-password
KEYCLOAK_ISSUER_URL=https://damsole.in/realms/agencyos
KEYCLOAK_JWKS_URI=https://damsole.in/auth/realms/agencyos/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=agencyos-api

# Reverse proxy
HTTP_PORT=80

# Backup scripts
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
BACKUP_DIR=./backups

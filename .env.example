# Application
NODE_ENV=development

# Backend API
PORT=3001
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=agencyos
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=agencyos-web

# PostgreSQL
POSTGRES_USER=agencyos
POSTGRES_PASSWORD=agencyos_dev
POSTGRES_DB=agencyos
POSTGRES_PORT=5432
DATABASE_URL=postgresql://agencyos:agencyos_dev@localhost:5432/agencyos?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Keycloak (OIDC)
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/agencyos
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/agencyos/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=agencyos-api

# API hardening
SWAGGER_ENABLED=true
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
STORAGE_LOCAL_PATH=uploads
STORAGE_MAX_FILE_SIZE_BYTES=10485760
